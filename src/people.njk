---
layout: layouts/base.njk
title: Our Team
permalink: /people/
---

<section class="team-section">
  <h1>Our Team</h1>
  <p>We are a multi-national group of researchers pushing the boundaries of Human-AI Interaction.</p>

  <div class="team-grid">
    {% for person in collections.people %}
      <div class="person-card">
        {% if person.data.image %}
          <img src="{{ person.data.image }}" alt="Photo of {{ person.data.name }}" class="person-photo">
        {% endif %}
        
        <h2 class="person-name">{{ person.data.name }}</h2>
        <p class="person-role">{{ person.data.role }}</p>
        
        <div class="person-bio">
          {{ person.templateContent | safe }}
        </div>

        {% if person.data.links %}
          <ul class="person-links">
            {% for link in person.data.links %}
              <li><a href="{{ link.url }}">{{ link.label }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>